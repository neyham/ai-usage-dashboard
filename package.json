{
  "name": "ai-usage-dashboard",
  "private": true,
  "version": "0.3.0",
  "license": "MIT",
  "description": "Local Windows desktop dashboard for Codex and Claude usage limits and DeepSeek API balance",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/neyham/ai-usage-dashboard.git"
  },
  "bugs": {
    "url": "https://github.com/neyham/ai-usage-dashboard/issues"
  },
  "homepage": "https://github.com/neyham/ai-usage-dashboard#readme",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "test": "npm run build && npm run test:ui",
    "test:ui": "node scripts/viewport-check.mjs",
    "test:rust": "cargo test --locked --all-targets --manifest-path src-tauri/Cargo.toml",
    "preview": "vite preview",
    "tauri": "tauri",
    "app:dev": "tauri dev",
    "app:build": "tauri build"
  },
  "dependencies": {
    "@fontsource/jetbrains-mono": "^5.2.8",
    "@fontsource/rajdhani": "^5.2.7",
    "@tauri-apps/api": "^2.1.1",
